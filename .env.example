# ====================================
# Database (Docker Compose Postgres)
# ====================================
# 호스트에서 실행되는 앱/Prisma는 localhost로 접근
DATABASE_URL="postgresql://gbl:gbl_dev_password@localhost:5432/girls_band_live?schema=public"

# 컨테이너 내부에서 접근할 때 사용 (앱을 컨테이너화하는 경우)
# DATABASE_URL="postgresql://gbl:gbl_dev_password@postgres:5432/girls_band_live?schema=public"

# 테스트용 별도 DB URL (Phase 2에서 사용)
TEST_DATABASE_URL="postgresql://gbl:gbl_dev_password@localhost:5432/girls_band_live_test?schema=public"

# ====================================
# Postgres (docker-compose에서 사용)
# ====================================
POSTGRES_USER=gbl
POSTGRES_PASSWORD=gbl_dev_password
POSTGRES_DB=girls_band_live

# ====================================
# Admin 인증 (Phase 2에서 사용)
# ====================================
# bcrypt 해시. 생성: pnpm tsx -e "import bcrypt from 'bcryptjs'; console.log(bcrypt.hashSync('YOUR_PASSWORD', 12))"
ADMIN_PASSWORD_HASH=""

# JWT 시크릿. 최소 32바이트. 생성: openssl rand -hex 32
JWT_SECRET=""

# ====================================
# Timezone
# ====================================
TZ=Asia/Tokyo
